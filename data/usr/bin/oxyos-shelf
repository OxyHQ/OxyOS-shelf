# ---------------------------------------------------------------------------
# Utilities
# ---------------------------------------------------------------------------

def load_css():
    provider = Gtk.CssProvider()
    provider.load_from_data(CSS)
    Gtk.StyleContext.add_provider_for_screen(
        Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
    )


def load_config():
    """Load pinned apps list from config, or create default."""
    if os.path.isfile(CONFIG_FILE):
        try:
            with open(CONFIG_FILE) as f:
                data = json.load(f)
            return data.get("pinned", DEFAULT_PINS)
        except (json.JSONDecodeError, IOError):
            pass
    return list(DEFAULT_PINS)


def save_config(pinned):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump({"pinned": pinned}, f, indent=2)


def parse_desktop_file(path):
    """Parse a .desktop file, return dict with Name, Icon, Exec, or None."""
    kf = GLib.KeyFile()
    try:
        kf.load_from_file(path, GLib.KeyFileFlags.NONE)
    except GLib.Error:
        return None

    try:
        dtype = kf.get_string("Desktop Entry", "Type")
        if dtype != "Application":
            return None
    except GLib.Error:
        return None

    # Skip hidden / NoDisplay entries
    try:
        if kf.get_boolean("Desktop Entry", "NoDisplay"):
            return None
    except GLib.Error:
        pass
    try:
        if kf.get_boolean("Desktop Entry", "Hidden"):
            return None
    except GLib.Error:
        pass

    try:
        name = kf.get_locale_string("Desktop Entry", "Name", None)
    except GLib.Error:
        return None

    try:
        icon = kf.get_string("Desktop Entry", "Icon")
    except GLib.Error:
        icon = "application-x-executable"

    try:
        exe = kf.get_string("Desktop Entry", "Exec")
        # Strip field codes (%u, %U, %f, %F, etc.)
        exe = " ".join(p for p in exe.split() if not p.startswith("%"))
    except GLib.Error:
        exe = ""

    return {"name": name, "icon": icon, "exec": exe, "file": os.path.basename(path)}


def get_all_apps():
    """Return sorted list of parsed .desktop entries."""
    seen = set()
    apps = []
    for d in DESKTOP_DIRS:
        for path in glob.glob(os.path.join(d, "*.desktop")):
            basename = os.path.basename(path)
            if basename in seen:
                continue
            seen.add(basename)
            info = parse_desktop_file(path)
            if info and info["exec"]:
                apps.append(info)
    apps.sort(key=lambda a: a["name"].lower())
    return apps


def load_icon(icon_name, size):
    """Load icon pixbuf from theme, with fallback."""
    theme = Gtk.IconTheme.get_default()
    try:
        return theme.load_icon(icon_name, size, Gtk.IconLookupFlags.FORCE_SIZE)
    except GLib.Error:
        pass
    # Try as absolute path
    if os.path.isfile(icon_name):
        try:
            return GdkPixbuf.Pixbuf.new_from_file_at_scale(icon_name, size, size, True)
        except GLib.Error:
            pass
    # Fallback
    try:
        return theme.load_icon("application-x-executable", size, Gtk.IconLookupFlags.FORCE_SIZE)
    except GLib.Error:
        return None


def get_running_wm_classes():
    """Get set of WM_CLASS values for running windows via _NET_CLIENT_LIST."""
    try:
        display = Gdk.Display.get_default()
        screen = display.get_default_screen()
        root = screen.get_root_window()
        atom_client_list = Gdk.Atom.intern("_NET_CLIENT_LIST", False)
        result = Gdk.property_get(root, atom_client_list, Gdk.Atom.intern("WINDOW", False),
                                  0, 1024, False)
        if result is None:
            return set()
        # result is (actual_type, actual_format, data)
        data = result[2]
        classes = set()
        # data is a list of 32-bit window IDs
        for i in range(0, len(data), 4):
            xid = int.from_bytes(data[i:i+4], byteorder="little")
            try:
                win = GdkX11.X11Window.foreign_new_for_display(display, xid)
                if win is None:
                    continue
                # Get WM_CLASS via _GTK_APPLICATION_ID or fall back
                wm_class_atom = Gdk.Atom.intern("WM_CLASS", False)
                wm_result = Gdk.property_get(win, wm_class_atom,
                                             Gdk.Atom.intern("STRING", False),
                                             0, 1024, False)
                if wm_result and wm_result[2]:
                    # WM_CLASS is two null-terminated strings
                    raw = bytes(wm_result[2])
                    parts = raw.replace(b"\x00", b" ").decode("utf-8", errors="replace").split()
                    for p in parts:
                        classes.add(p.lower())
            except Exception:
                continue
        return classes
    except Exception:
        return set()


def launch_app(exe):
    """Launch an application command in the background."""
    try:
        subprocess.Popen(exe, shell=True, start_new_session=True,
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass


# ---------------------------------------------------------------------------
# PinnedIcon — a single icon in the dock
# ---------------------------------------------------------------------------

class PinnedIcon(Gtk.EventBox):
    """A single pinned app icon with running indicator dot."""

    def __init__(self, app_info):
        super().__init__()
        self.app_info = app_info
        self.is_running = False

        self.set_size_request(44, 44)
        self.set_tooltip_text(app_info["name"])
        self.set_events(Gdk.EventMask.ENTER_NOTIFY_MASK | Gdk.EventMask.LEAVE_NOTIFY_MASK)
        self.connect("enter-notify-event", self._on_enter)
        self.connect("leave-notify-event", self._on_leave)
        self.connect("button-press-event", self._on_click)

        self._hover = False

        self.drawing = Gtk.DrawingArea()
        self.drawing.set_size_request(44, 44)
        self.drawing.connect("draw", self._on_draw)
        self.add(self.drawing)

        self._pixbuf = load_icon(app_info["icon"], ICON_SIZE)

    def _on_enter(self, w, e):
        self._hover = True
        self.drawing.queue_draw()

    def _on_leave(self, w, e):
        self._hover = False
        self.drawing.queue_draw()

    def _on_click(self, w, e):
        if e.button == 1:
            launch_app(self.app_info["exec"])

    def _on_draw(self, widget, cr):
        alloc = widget.get_allocation()
        cx, cy = alloc.width / 2, alloc.height / 2

        # Hover background
        if self._hover:
            cr.set_source_rgba(1, 1, 1, 0.12)
            cr.arc(cx, cy - 2, 20, 0, 6.2832)
            cr.fill()

        # Icon
        if self._pixbuf:
            icon_x = cx - ICON_SIZE / 2
            icon_y = cy - ICON_SIZE / 2 - 2
            Gdk.cairo_set_source_pixbuf(cr, self._pixbuf, icon_x, icon_y)
            cr.paint()

        # Running indicator dot
        if self.is_running:
            cr.set_source_rgba(1, 1, 1, 0.9)
            cr.arc(cx, alloc.height - 3, DOT_RADIUS, 0, 6.2832)
            cr.fill()

        return True

    def update_running(self, running_classes):
        """Check if this app is running based on WM_CLASS matching."""
        # Match against the .desktop filename (without extension) or the exec basename
        desktop_id = self.app_info["file"].replace(".desktop", "").lower()
        exe_base = os.path.basename(self.app_info["exec"].split()[0]).lower() if self.app_info["exec"] else ""
        was_running = self.is_running
        self.is_running = desktop_id in running_classes or exe_base in running_classes
        if self.is_running != was_running:
            self.drawing.queue_draw()


# ---------------------------------------------------------------------------
# LauncherButton — the circle button with grid dots
# ---------------------------------------------------------------------------

class LauncherButton(Gtk.EventBox):
    """Circle button with a 3x3 grid-dot icon."""

    def __init__(self, click_cb):
        super().__init__()
        self.set_size_request(40, 40)
        self._hover = False
        self._click_cb = click_cb

        self.set_events(Gdk.EventMask.ENTER_NOTIFY_MASK | Gdk.EventMask.LEAVE_NOTIFY_MASK)
        self.connect("enter-notify-event", lambda w, e: self._set_hover(True))
        self.connect("leave-notify-event", lambda w, e: self._set_hover(False))
        self.connect("button-press-event", self._on_click)

        self.da = Gtk.DrawingArea()
        self.da.set_size_request(40, 40)
        self.da.connect("draw", self._on_draw)
        self.add(self.da)

    def _set_hover(self, h):
        self._hover = h
        self.da.queue_draw()

    def _on_click(self, w, e):
        if e.button == 1:
            self._click_cb()

    def _on_draw(self, widget, cr):
        w = widget.get_allocation().width
        h = widget.get_allocation().height
        cx, cy = w / 2, h / 2
        r = 19

        # Circle background
        if self._hover:
            cr.set_source_rgba(1, 1, 1, 0.18)
        else:
            cr.set_source_rgba(1, 1, 1, 0.08)
        cr.arc(cx, cy, r, 0, 6.2832)
        cr.fill()

        # 3x3 dot grid
        cr.set_source_rgba(1, 1, 1, 0.85)
        dot_r = 2.2
        spacing = 7
        for row in range(-1, 2):
            for col in range(-1, 2):
                cr.arc(cx + col * spacing, cy + row * spacing, dot_r, 0, 6.2832)
                cr.fill()

        return True


# ---------------------------------------------------------------------------
# TrayArea — clock + status icons + quick settings
# ---------------------------------------------------------------------------

class TrayArea(Gtk.Box):
    """System tray: status icons + clock, opens quick-settings on click."""

    def __init__(self):
        super().__init__(orientation=Gtk.Orientation.HORIZONTAL, spacing=2)
        self.set_valign(Gtk.Align.CENTER)

        # Status icons
        theme = Gtk.IconTheme.get_default()
        for icon_name in ["network-wireless-symbolic", "audio-volume-medium-symbolic"]:
            img = self._make_tray_icon(icon_name, theme)
            if img:
                self.pack_start(img, False, False, 0)

        # Battery (only if present)
        self._battery_path = self._find_battery()
        if self._battery_path:
            self._battery_img = self._make_tray_icon("battery-good-symbolic", theme)
            if self._battery_img:
                self.pack_start(self._battery_img, False, False, 0)
                GLib.timeout_add_seconds(60, self._update_battery)

        # Clock
        self._clock = Gtk.Label()
        self._clock.set_name("clock-label")
        self._update_clock()
        GLib.timeout_add_seconds(30, self._update_clock)

        clock_btn = Gtk.EventBox()
        clock_btn.add(self._clock)
        clock_btn.set_events(Gdk.EventMask.BUTTON_PRESS_MASK)
        clock_btn.connect("button-press-event", self._on_clock_click)
        self.pack_start(clock_btn, False, False, 0)

        # Quick settings popover
        self._popover = None

    def _make_tray_icon(self, name, theme):
        try:
            pb = theme.load_icon(name, 18, Gtk.IconLookupFlags.FORCE_SIZE)
        except GLib.Error:
            return None
        img = Gtk.Image.new_from_pixbuf(pb)
        btn = Gtk.EventBox()
        btn.set_name("tray-btn")
        btn.add(img)
        btn.set_valign(Gtk.Align.CENTER)
        return btn

    def _find_battery(self):
        for p in glob.glob("/sys/class/power_supply/BAT*"):
            if os.path.isfile(os.path.join(p, "capacity")):
                return p
        return None

    def _update_battery(self):
        if not self._battery_path or not self._battery_img:
            return False
        try:
            with open(os.path.join(self._battery_path, "capacity")) as f:
                cap = int(f.read().strip())
            if cap > 80:
                icon = "battery-full-symbolic"
            elif cap > 50:
                icon = "battery-good-symbolic"
            elif cap > 20:
                icon = "battery-low-symbolic"
            else:
                icon = "battery-caution-symbolic"
            theme = Gtk.IconTheme.get_default()
            pb = theme.load_icon(icon, 18, Gtk.IconLookupFlags.FORCE_SIZE)
            child = self._battery_img.get_child()
            if isinstance(child, Gtk.Image):
                child.set_from_pixbuf(pb)
            self._battery_img.set_tooltip_text(f"Battery: {cap}%")
        except Exception:
            pass
        return True

    def _update_clock(self):
        self._clock.set_text(time.strftime("%H:%M"))
        return True

    def _on_clock_click(self, w, e):
        if e.button == 1:
            self._show_quick_settings(w)

    def _show_quick_settings(self, relative_to):
        if self._popover and self._popover.get_visible():
            self._popover.popdown()
            return

        self._popover = Gtk.Popover()
        self._popover.set_relative_to(relative_to)
        self._popover.set_position(Gtk.PositionType.TOP)
        self._popover.set_name("quick-settings")

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        vbox.set_margin_start(8)
        vbox.set_margin_end(8)
        vbox.set_margin_top(8)
        vbox.set_margin_bottom(8)

        # Date / time header
        date_label = Gtk.Label()
        date_label.set_markup(
            f'<span color="white" size="large" weight="bold">{time.strftime("%H:%M")}</span>'
            f'\n<span color="rgba(255,255,255,0.6)" size="small">{time.strftime("%A, %B %d")}</span>'
        )
        date_label.set_xalign(0)
        vbox.pack_start(date_label, False, False, 0)

        vbox.pack_start(Gtk.Separator(), False, False, 0)

        # Volume slider
        vol_label = Gtk.Label(label="Volume")
        vol_label.set_name("qs-label")
        vol_label.set_xalign(0)
        vbox.pack_start(vol_label, False, False, 0)

        vol_scale = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, 0, 100, 5)
        vol_scale.set_draw_value(False)
        vol_scale.set_size_request(220, -1)
        current_vol = self._get_volume()
        vol_scale.set_value(current_vol)
        vol_scale.connect("value-changed", self._on_volume_changed)
        vbox.pack_start(vol_scale, False, False, 0)

        # Brightness slider (if backlight available)
        bl_path = self._find_backlight()
        if bl_path:
            br_label = Gtk.Label(label="Brightness")
            br_label.set_name("qs-label")
            br_label.set_xalign(0)
            vbox.pack_start(br_label, False, False, 0)

            br_scale = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, 5, 100, 5)
            br_scale.set_draw_value(False)
            br_scale.set_size_request(220, -1)
            current_br = self._get_brightness(bl_path)
            br_scale.set_value(current_br)
            br_scale.connect("value-changed", lambda s: self._set_brightness(bl_path, s.get_value()))
            vbox.pack_start(br_scale, False, False, 0)

        vbox.pack_start(Gtk.Separator(), False, False, 0)

        # Action buttons
        btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)

        wifi_btn = Gtk.Button(label="Wi-Fi")
        wifi_btn.set_name("qs-button")
        wifi_btn.connect("clicked", lambda b: self._toggle_wifi())
        btn_box.pack_start(wifi_btn, True, True, 0)

        restart_btn = Gtk.Button(label="Restart")
        restart_btn.set_name("qs-button")
        restart_btn.connect("clicked", lambda b: os.system("systemctl reboot"))
        btn_box.pack_start(restart_btn, True, True, 0)

        shutdown_btn = Gtk.Button(label="Shut Down")
        shutdown_btn.set_name("qs-button")
        shutdown_btn.connect("clicked", lambda b: os.system("systemctl poweroff"))
        btn_box.pack_start(shutdown_btn, True, True, 0)

        vbox.pack_start(btn_box, False, False, 0)

        self._popover.add(vbox)
        self._popover.show_all()
        self._popover.popup()

    def _get_volume(self):
        try:
            out = subprocess.check_output(
                ["wpctl", "get-volume", "@DEFAULT_AUDIO_SINK@"],
                stderr=subprocess.DEVNULL, timeout=2
            ).decode()
            # Output: "Volume: 0.50" or "Volume: 0.50 [MUTED]"
            val = float(out.split()[1])
            return int(val * 100)
        except Exception:
            try:
                out = subprocess.check_output(
                    ["pactl", "get-sink-volume", "@DEFAULT_SINK@"],
                    stderr=subprocess.DEVNULL, timeout=2
                ).decode()
                for part in out.split():
                    if "%" in part:
                        return int(part.replace("%", ""))
            except Exception:
                pass
        return 50

    def _on_volume_changed(self, scale):
        vol = int(scale.get_value())
        try:
            subprocess.Popen(
                ["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", f"{vol/100:.2f}"],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
            )
        except FileNotFoundError:
            subprocess.Popen(
                ["pactl", "set-sink-volume", "@DEFAULT_SINK@", f"{vol}%"],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
            )

    def _find_backlight(self):
        for p in glob.glob("/sys/class/backlight/*"):
            if os.path.isfile(os.path.join(p, "brightness")):
                return p
        return None

    def _get_brightness(self, bl_path):
        try:
            with open(os.path.join(bl_path, "brightness")) as f:
                cur = int(f.read().strip())
            with open(os.path.join(bl_path, "max_brightness")) as f:
                mx = int(f.read().strip())
            return int(cur / mx * 100) if mx > 0 else 50
        except Exception:
            return 50

    def _set_brightness(self, bl_path, pct):
        try:
            with open(os.path.join(bl_path, "max_brightness")) as f:
                mx = int(f.read().strip())
            val = max(1, int(pct / 100 * mx))
            # Use pkexec or direct write (may need polkit rule)
            subprocess.Popen(
                ["pkexec", "bash", "-c", f"echo {val} > {bl_path}/brightness"],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
            )
        except Exception:
            pass

    def _toggle_wifi(self):
        try:
            out = subprocess.check_output(
                ["nmcli", "radio", "wifi"], stderr=subprocess.DEVNULL, timeout=2
            ).decode().strip()
            new_state = "off" if out == "enabled" else "on"
            subprocess.Popen(
                ["nmcli", "radio", "wifi", new_state],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
            )
        except Exception:
            pass


# ---------------------------------------------------------------------------
# AppLauncher — fullscreen-ish overlay with search + app grid
# ---------------------------------------------------------------------------

class AppLauncher(Gtk.Window):
    """App launcher overlay that slides up from the shelf."""

    def __init__(self):
        super().__init__(type=Gtk.WindowType.TOPLEVEL)
        self.set_name("app-launcher")
        self.set_decorated(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        self.set_keep_above(True)
        self.set_type_hint(Gdk.WindowTypeHint.DOCK)

        # Position: fill screen above shelf
        display = Gdk.Display.get_default()
        monitor = display.get_primary_monitor() or display.get_monitor(0)
        geo = monitor.get_geometry()
        self._screen_w = geo.width
        self._screen_h = geo.height
        launcher_h = self._screen_h - SHELF_HEIGHT
        self.set_size_request(self._screen_w, launcher_h)
        self.move(geo.x, geo.y)
        self.set_default_size(self._screen_w, launcher_h)

        # Make background transparent
        screen = self.get_screen()
        visual = screen.get_rgba_visual()
        if visual:
            self.set_visual(visual)
        self.set_app_paintable(True)

        # Layout
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        vbox.set_margin_start(int(self._screen_w * 0.15))
        vbox.set_margin_end(int(self._screen_w * 0.15))
        vbox.set_margin_top(60)

        # Search
        self._search = Gtk.Entry()
        self._search.set_name("search-entry")
        self._search.set_placeholder_text("Search apps...")
        self._search.connect("changed", self._on_search)
        vbox.pack_start(self._search, False, False, 16)

        # Scrollable grid
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)

        self._flowbox = Gtk.FlowBox()
        self._flowbox.set_max_children_per_line(6)
        self._flowbox.set_min_children_per_line(4)
        self._flowbox.set_selection_mode(Gtk.SelectionMode.NONE)
        self._flowbox.set_homogeneous(True)
        self._flowbox.set_row_spacing(4)
        self._flowbox.set_column_spacing(4)
        self._flowbox.set_filter_func(self._filter_func)
        scroll.add(self._flowbox)
        vbox.pack_start(scroll, True, True, 0)

        self.add(vbox)
        self._apps = []
        self._search_text = ""

        self.connect("key-press-event", self._on_key)
        self.connect("draw", self._on_draw)

    def populate(self):
        """Load all apps into the grid."""
        # Clear
        for child in self._flowbox.get_children():
            self._flowbox.remove(child)
        self._apps = get_all_apps()
        for app in self._apps:
            item = self._make_app_item(app)
            self._flowbox.add(item)
        self._flowbox.show_all()

    def _make_app_item(self, app):
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        vbox.set_halign(Gtk.Align.CENTER)
        vbox.set_valign(Gtk.Align.START)

        pb = load_icon(app["icon"], LAUNCHER_ICON_SIZE)
        if pb:
            img = Gtk.Image.new_from_pixbuf(pb)
        else:
            img = Gtk.Image.new_from_icon_name("application-x-executable", Gtk.IconSize.DIALOG)
        vbox.pack_start(img, False, False, 0)

        label = Gtk.Label(label=app["name"])
        label.set_name("app-label")
        label.set_max_width_chars(12)
        label.set_ellipsize(Pango.EllipsizeMode.END)
        label.set_justify(Gtk.Justification.CENTER)
        vbox.pack_start(label, False, False, 0)

        btn = Gtk.Button()
        btn.set_name("app-grid-item")
        btn.set_relief(Gtk.ReliefStyle.NONE)
        btn.add(vbox)
        btn.connect("clicked", lambda b, a=app: self._launch(a))
        btn._app_info = app  # stash for filtering
        return btn

    def _launch(self, app):
        launch_app(app["exec"])
        self.hide()

    def _on_search(self, entry):
        self._search_text = entry.get_text().lower()
        self._flowbox.invalidate_filter()

    def _filter_func(self, child):
        if not self._search_text:
            return True
        btn = child.get_child()
        if hasattr(btn, "_app_info"):
            return self._search_text in btn._app_info["name"].lower()
        return True

    def _on_key(self, w, e):
        if e.keyval == Gdk.KEY_Escape:
            self.hide()
            return True
        return False

    def _on_draw(self, widget, cr):
        alloc = widget.get_allocation()
        # Semi-transparent dark background
        cr.set_source_rgba(26/255, 26/255, 46/255, 0.94)
        cr.rectangle(0, 0, alloc.width, alloc.height)
        cr.fill()
        return False

    def toggle(self):
        if self.get_visible():
            self.hide()
        else:
            self._search.set_text("")
            self.populate()
            self.show_all()
            self._search.grab_focus()


# ---------------------------------------------------------------------------
# Shelf — the main dock window
# ---------------------------------------------------------------------------

class Shelf(Gtk.Window):
    """The main shelf/dock window."""

    def __init__(self):
        super().__init__(type=Gtk.WindowType.TOPLEVEL)
        self.set_name("shelf")
        self.set_title("OxyOS Shelf")
        self.set_decorated(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        self.set_type_hint(Gdk.WindowTypeHint.DOCK)
        self.stick()

        # Transparency
        screen = self.get_screen()
        visual = screen.get_rgba_visual()
        if visual:
            self.set_visual(visual)
        self.set_app_paintable(True)

        # Size & position
        display = Gdk.Display.get_default()
        monitor = display.get_primary_monitor() or display.get_monitor(0)
        geo = monitor.get_geometry()
        self._screen_w = geo.width
        self._screen_h = geo.height
        self._mon_x = geo.x
        self._mon_y = geo.y

        self.set_size_request(self._screen_w, SHELF_HEIGHT)
        self.set_default_size(self._screen_w, SHELF_HEIGHT)
        self.move(self._mon_x, self._mon_y + self._screen_h - SHELF_HEIGHT)

        # App launcher
        self._launcher = AppLauncher()

        # Main layout: [launcher_btn | ---- pinned center ---- | tray]
        self._hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        self._hbox.set_valign(Gtk.Align.CENTER)

        # Left: launcher button
        left_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        left_box.set_margin_start(8)
        launcher_btn = LauncherButton(self._toggle_launcher)
        left_box.pack_start(launcher_btn, False, False, 0)
        self._hbox.pack_start(left_box, False, False, 0)

        # Center: pinned apps (expand to fill, contents centered)
        self._center_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
        self._center_box.set_halign(Gtk.Align.CENTER)
        self._center_box.set_valign(Gtk.Align.CENTER)
        self._hbox.pack_start(self._center_box, True, True, 0)

        # Right: system tray
        self._tray = TrayArea()
        right_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        right_box.set_margin_end(12)
        right_box.pack_end(self._tray, False, False, 0)
        self._hbox.pack_end(right_box, False, False, 0)

        self.add(self._hbox)

        # Load pinned apps
        self._pinned_icons = []
        self._load_pinned()

        # Track running apps every 3 seconds
        GLib.timeout_add_seconds(3, self._update_running)

        # Set struts after mapping
        self.connect("realize", self._on_realize)

    def _on_realize(self, widget):
        """Set _NET_WM_STRUT_PARTIAL to reserve screen space at the bottom."""
        gdk_win = self.get_window()
        if not isinstance(gdk_win, GdkX11.X11Window):
            return

        xid = gdk_win.get_xid()
        display = GdkX11.X11Display.get_default()
        xdisplay = display.get_xdisplay()

        # _NET_WM_STRUT_PARTIAL: left, right, top, bottom,
        #   left_start_y, left_end_y, right_start_y, right_end_y,
        #   top_start_x, top_end_x, bottom_start_x, bottom_end_x
        strut_data = [
            0, 0, 0, SHELF_HEIGHT,
            0, 0, 0, 0,
            0, 0, self._mon_x, self._mon_x + self._screen_w - 1
        ]

        # Set via GDK property
        atom_strut = Gdk.Atom.intern("_NET_WM_STRUT_PARTIAL", False)
        atom_cardinal = Gdk.Atom.intern("CARDINAL", False)
        import struct
        data = struct.pack(f"={len(strut_data)}I", *strut_data)
        Gdk.property_change(gdk_win, atom_strut, atom_cardinal, 32,
                            Gdk.PropMode.REPLACE, data)

        # Also set the simpler _NET_WM_STRUT
        atom_strut_simple = Gdk.Atom.intern("_NET_WM_STRUT", False)
        simple_data = struct.pack("=4I", 0, 0, 0, SHELF_HEIGHT)
        Gdk.property_change(gdk_win, atom_strut_simple, atom_cardinal, 32,
                            Gdk.PropMode.REPLACE, simple_data)

    def _load_pinned(self):
        """Load pinned apps and create icon widgets."""
        for child in self._center_box.get_children():
            self._center_box.remove(child)

        self._pinned_icons = []
        pinned = load_config()
        all_apps = {a["file"]: a for a in get_all_apps()}

        for desktop_file in pinned:
            if desktop_file in all_apps:
                icon = PinnedIcon(all_apps[desktop_file])
                self._pinned_icons.append(icon)
                self._center_box.pack_start(icon, False, False, 0)

        self._center_box.show_all()

    def _update_running(self):
        """Poll running windows and update indicator dots."""
        classes = get_running_wm_classes()
        for icon in self._pinned_icons:
            icon.update_running(classes)
        return True

    def _toggle_launcher(self):
        self._launcher.toggle()


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    load_css()

    # Ensure default config exists
    if not os.path.isfile(CONFIG_FILE):
        save_config(DEFAULT_PINS)

    shelf = Shelf()
    shelf.connect("destroy", Gtk.main_quit)
    shelf.show_all()

    Gtk.main()


if __name__ == "__main__":
    main()
