#!/usr/bin/env python3
"""
OxyOS Shelf — ChromeOS-style dock for Openbox/X11.

A bottom panel with app launcher, pinned icons, and system tray.
Requires: python3-gi, gir1.2-gtk-3.0 (standard on Debian).
"""

import json
import os
import glob
import subprocess
import time

import gi
gi.require_version("Gtk", "3.0")
gi.require_version("Gdk", "3.0")
gi.require_version("GdkX11", "3.0")
from gi.repository import Gtk, Gdk, GdkX11, GLib, GdkPixbuf, Gio, Pango

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

SHELF_HEIGHT = 48
ICON_SIZE = 36
LAUNCHER_ICON_SIZE = 48
DOT_RADIUS = 2.5
CONFIG_DIR = os.path.expanduser("~/.config/oxyos")
CONFIG_FILE = os.path.join(CONFIG_DIR, "shelf.json")
DESKTOP_DIRS = ["/usr/share/applications", os.path.expanduser("~/.local/share/applications")]
DEFAULT_PINS = ["thunar.desktop", "firefox-esr.desktop", "terminator.desktop", "geany.desktop"]

# ---------------------------------------------------------------------------
# CSS
# ---------------------------------------------------------------------------

